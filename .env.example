# Copy to .env and fill in real values. Never commit .env.
# python-dotenv loads this from the project root (see config/settings.py).

# ── Core ───────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# When DEBUG is False, set to True only if you serve /media/ from Django (e.g. small deploy)
FORCE_SERVE_MEDIA=True
# Comma-separated extra CSRF origins (default localhost/127.0.0.1 are already in settings)
# CSRF_TRUSTED_ORIGINS=https://app.example.com,https://www.example.com

# ── Database (omit DB_ENGINE or leave empty for SQLite) ───
# For PostgreSQL, set:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=tenant_db
# DB_USER=tenant_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432
# For SQLite (default), only this path/filename is used (relative to project root):
DB_NAME=db.sqlite3

# ── JWT (Simple JWT) ───────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email ─────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
FRONTEND_URL=http://localhost:3000

# ── SMS (optional) ────────────────────────────────────────
SMS_GATEWAY_URL=
SMS_API_KEY=
SMS_SENDER_ID=
